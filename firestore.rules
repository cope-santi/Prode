rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid == 'eP44roQf40ZOgh0rZYnsh91y7vI3';
    }

    function isTournamentDoc() {
      return request.resource.data.tournamentId is string;
    }

    function noPredictionPii() {
      return !('userEmail' in request.resource.data);
    }

    function validPredictionOwner() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.gameId is string
        && request.resource.data.playerName is string
        && request.resource.data.predictedHomeScore is int
        && request.resource.data.predictedAwayScore is int
        && request.resource.data.predictedHomeScore >= 0
        && request.resource.data.predictedAwayScore >= 0;
    }

    match /games/{gameId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /predictions/{predictionId} {
      allow read: if true;
      allow create, update: if validPredictionOwner()
        && noPredictionPii()
        && isTournamentDoc()
        && predictionId == request.auth.uid + '_' + request.resource.data.gameId;
      allow delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /sync_status/{statusId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sync_locks/{lockId} {
      allow read, write: if isAdmin();
    }

    match /public_cache/{cacheId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /public_results/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
